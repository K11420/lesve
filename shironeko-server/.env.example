# LenovoServer Environment Configuration

# JWT Secret (セキュアなランダム文字列を設定)
JWT_SECRET=your-secure-jwt-secret-key-here
# 追加許可するCORSオリジン（カンマ区切り、任意）
# PUBLIC_HOST / ADMIN_HOST / CHAT_HOST は自動で許可されます
CORS_ALLOWED_ORIGINS=

# チャット専用サイトとして使うドメイン（任意）
# 例: chat.lesve.tech
CHAT_HOST=

# Discord OAuth設定
# Discord Developer Portal (https://discord.com/developers/applications) で取得
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# 問い合わせ新規作成時の通知先（Discord Incoming Webhook URL）
DISCORD_SUPPORT_WEBHOOK_URL=
# 任意: @here や <@&ROLE_ID> などを通知本文に入れる
DISCORD_SUPPORT_NOTIFY_MENTION=
# コンプライアンス通知先（利用規約違反・監査系）
DISCORD_COMPLIANCE_WEBHOOK_URL=
DISCORD_COMPLIANCE_NOTIFY_MENTION=
# 運用監視通知先（5xx増加・バックアップ異常・VM不整合など）
DISCORD_OPS_WEBHOOK_URL=
DISCORD_OPS_NOTIFY_MENTION=

# Stripe設定
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_STANDARD_COUPON_ID=coupon_xxx
# 任意: Checkoutで使う決済手段（カンマ区切り）
# 未指定ならStripeのDynamic Payment Methodsを使用
# 例: card,link,us_bank_account
# 例: card,link,crypto (CryptoはStripe側の有効化と条件を満たす必要あり)
STRIPE_PAYMENT_METHOD_TYPES=

# 一括メール配信（管理者機能）
MAILER_ENABLED=false
MAILER_SMTP_HOST=
MAILER_SMTP_PORT=587
MAILER_SMTP_SECURE=false
MAILER_SMTP_USER=
MAILER_SMTP_PASS=
MAILER_SMTP_REJECT_UNAUTHORIZED=true
MAILER_FROM_EMAIL=
MAILER_FROM_NAME=LenovoServer
MAILER_REPLY_TO=
MAILER_MAX_RECIPIENTS=3000
MAILER_SEND_DELAY_MS=120

# 各種通知の送信先（カンマ区切り可）
NOTIFY_EMAIL_TO=koutarou114@outlook.jp
NOTIFY_SUBJECT_PREFIX=[LenovoServer]

# 監視/バックアップ制御
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_MODE=full
AUTO_BACKUP_STARTUP_MODE=db
AUTO_BACKUP_INTERVAL_MINUTES=1440
AUTO_BACKUP_TIMEOUT_MINUTES=180
AUTO_BACKUP_RETENTION_DAYS=14
AUTO_BACKUP_RESTORE_CHECK_ENABLED=true
AUTO_BACKUP_NOTIFY_ENABLED=true
SYSTEM_MONITOR_ENABLED=true
SYSTEM_MONITOR_INTERVAL_SECONDS=300
SYSTEM_MONITOR_ALERT_COOLDOWN_MINUTES=30
SYSTEM_MONITOR_DISK_WARN_PERCENT=85
SYSTEM_MONITOR_DB_WARN_MB=2048
SYSTEM_MONITOR_RSS_WARN_MB=900
SYSTEM_MONITOR_API_5XX_WINDOW_SECONDS=300
SYSTEM_MONITOR_API_5XX_WARN_COUNT=5
SYSTEM_MONITOR_BACKUP_STALE_MINUTES=2880
SYSTEM_MONITOR_BACKUP_FAILURE_WINDOW_MINUTES=180
SYSTEM_MONITOR_BACKUP_FAILURE_WARN_COUNT=1
SYSTEM_MONITOR_STRIPE_FAILURE_WINDOW_MINUTES=180
SYSTEM_MONITOR_STRIPE_FAILURE_WARN_COUNT=1
SYSTEM_MONITOR_VM_STOPPED_GRACE_MINUTES=10
SYSTEM_MONITOR_VM_STOPPED_CHECK_LIMIT=30
